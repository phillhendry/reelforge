# ReelForge Configuration
# ========================

# Groq API key for Whisper transcription (fast + cheap)
GROQ_API_KEY=

# Anthropic API key for Claude analysis (edit decisions)
ANTHROPIC_API_KEY=

# Server port for the render API
PORT=3100

# Paths
INPUT_DIR=./input
OUTPUT_DIR=./output
TEMP_DIR=./temp

# Branding
BRAND_PRIMARY_COLOR=#ffffff
BRAND_ACCENT_COLOR=#E8FF00
BRAND_FONT_FAMILY=Inter
CAPTION_STYLE=highlight
