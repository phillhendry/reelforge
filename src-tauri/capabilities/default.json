{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "positioner:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "npx",
          "cmd": "npx",
          "args": true,
          "sidecar": false
        }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "npx",
          "cmd": "npx",
          "args": true,
          "sidecar": false
        }
      ]
    }
  ]
}
