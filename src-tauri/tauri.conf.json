{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ReelForge",
  "version": "1.0.0",
  "identifier": "com.reelforge.desktop",
  "build": {
    "devUrl": "http://localhost:3100",
    "frontendDist": "http://localhost:3100"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [],
    "security": {
      "dangerousDisableAssetCspModification": true
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
